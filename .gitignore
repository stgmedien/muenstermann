# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# Access source files — NIE ins Repo committen (Originaldaten)
*.accdb
*.mdb
*.laccdb

# Daten-Snapshots / Stichproben (können personenbezogen sein)
inventory/samples/
inventory/reports/*.html
*.parquet

# Generierte ETL-Seeds: enthalten Echtdaten, sind aus Quelle+Code reproduzierbar
schema/seeds/*.sql

# Secrets
.env
.env.*
!.env.example
ops/secrets/*
!ops/secrets/.env.example

# Tools (große Binaries — werden lokal gehalten, nicht versioniert)
tools/*.zip
tools/*.tar.gz
tools/*.class
tools/jdk/
tools/UCanAccess-*/
!tools/.gitkeep

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# Logs / Ergebnisse von Migrationsläufen
logs/
*.log

# DB-Dumps
*.sql.gz
*.dump
